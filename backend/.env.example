# Server
AC_HOST=0.0.0.0
AC_PORT=8301
AC_CORS_ORIGINS=["http://localhost:8300"]

# MongoDB
AC_MONGO_URI=mongodb://localhost:27017
AC_MONGO_DB=agent_chat

# File Storage
AC_DATA_DIR=data

# LLM - Primary (Poe)
AC_LLM_PROVIDER=poe
AC_POE_API_KEY=your-poe-api-key
AC_POE_MODEL=Gemini-3-Flash
AC_POE_BASE_URL=https://api.poe.com/v1

# LLM - Backup (Kimi)
AC_KIMI_API_KEY=your-kimi-api-key
AC_KIMI_MODEL=kimi-k2.5
AC_KIMI_BASE_URL=https://kimi-k2.ai/api/v1

# GitHub OAuth
AC_GITHUB_CLIENT_ID=xxx
AC_GITHUB_CLIENT_SECRET=xxx

# JWT
AC_JWT_SECRET=xxx
AC_JWT_EXPIRY_MINUTES=10080

# Frontend
AC_FRONTEND_URL=http://localhost:8300

# Logging
AC_LOG_LEVEL=INFO
