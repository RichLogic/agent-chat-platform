# Server
AC_HOST=0.0.0.0
AC_PORT=8301
AC_CORS_ORIGINS=["http://localhost:8300"]

# MongoDB
AC_MONGO_URI=mongodb://localhost:27017
AC_MONGO_DB=agent_chat

# File Storage
AC_DATA_DIR=data
AC_MAX_UPLOAD_SIZE_MB=50

# LLM - Primary (Poe)
AC_LLM_PROVIDER=poe
AC_POE_API_KEY=your-poe-api-key
AC_POE_MODEL=Gemini-3-Flash
AC_POE_BASE_URL=https://api.poe.com/v1

# LLM - Backup (Kimi)
AC_KIMI_API_KEY=your-kimi-api-key
AC_KIMI_MODEL=kimi-k2.5
AC_KIMI_BASE_URL=https://kimi-k2.ai/api/v1

# Search (SerpAPI primary, Brave fallback)
AC_SERPAPI_KEY=
AC_BRAVE_SEARCH_KEY=

# NewsAPI
AC_NEWSAPI_KEY=

# GitHub OAuth
AC_GITHUB_CLIENT_ID=xxx
AC_GITHUB_CLIENT_SECRET=xxx

# JWT
AC_JWT_SECRET=xxx
AC_JWT_EXPIRY_MINUTES=10080
AC_EVAL_TOKEN=

# Frontend
AC_FRONTEND_URL=http://localhost:8300

# Embedding
AC_EMBEDDING_MODEL=all-MiniLM-L6-v2

# MCP Notes (leave empty to disable)
AC_MCP_NOTES_URL=
AC_NOTES_ROOT=data/notes

# Logging
AC_LOG_LEVEL=INFO
